# Copy to .env and fill in your values
# NEVER commit .env to version control

# Required for deployment to Celo networks
DEPLOYER_PRIVATE_KEY=0x...your_private_key_here

# Optional: override the AI agent address (defaults to second hardhat account locally)
AI_AGENT_ADDRESS=0x...

# Optional: override cUSD token address (defaults to well-known Celo addresses)
CUSD_ADDRESS=

# Optional: Celoscan API key for contract verification
CELOSCAN_API_KEY=
